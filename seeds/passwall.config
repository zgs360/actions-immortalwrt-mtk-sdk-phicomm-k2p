CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_phicomm_k2p=y

# 核心依赖
CONFIG_PACKAGE_libopenssl=y
CONFIG_PACKAGE_libpthread=y
CONFIG_PACKAGE_libstdcpp=y
CONFIG_PACKAGE_zlib=y

# 网络基础
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iptables-mod-iprange=y
CONFIG_PACKAGE_kmod-ipt-iprange=y

# PassWall核心
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y       # Xray核心（支持VLESS）
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Trojan=y     # Trojan协议
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks=y
CONFIG_PACKAGE_luci-app-passwall_Iptables_Transparent_Proxy=y

# 协议支持
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_xray-plugin=y
CONFIG_PACKAGE_trojan-plus=y
CONFIG_PACKAGE_simple-obfs=y

# 精简组件
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_microsocks=y
CONFIG_PACKAGE_resolveip=y

# 禁用所有非必要组件
CONFIG_PACKAGE_curl=n
CONFIG_PACKAGE_wget-ssl=n
CONFIG_PACKAGE_kmod-tcp-bbr=n
CONFIG_PACKAGE_kmod-wireguard=n
CONFIG_PACKAGE_luci-app-vlmcsd=n
CONFIG_PACKAGE_luci-theme-atmaterial=n

# 存储优化
CONFIG_TARGET_ROOTFS_PARTSIZE=16
CONFIG_TARGET_ROOTFS_SQUASHFS=y
